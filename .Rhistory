require(caret)
require(reticulate)
create_train_test_indices <- function(n_samples, n_folds = 4, seed = NULL) {
if (!is.null(seed)) {
set.seed(seed)
}
folds <- createFolds(1:n_samples, k = n_folds, list = TRUE, returnTrain = TRUE)
train_test_indices <- list()
for (i in 1:n_folds) {
train_ind <- folds[[i]]
test_ind <- setdiff(1:n_samples, train_ind)
train_test_indices[[i]] <- list(
train = train_ind,
test = test_ind
)
}
return(train_test_indices)
}
set.seed(seed)
mod <- mod_name # "205_PA_"
initialize_prediction_array <- function(n_rows, n_species, n_samples) {
array(NA, dim = c(n_rows, n_species, n_samples))
}
nSamples <- nSamples %||% hM$samples
thin <- thin %||% hM$thin
nChains <- nChains %||% length(hM$postList)
verbose <- verbose %||% if(is.null(hM$verbose)) 10 else hM$verbose
cv_dir <- file.path(save_dir)
# cv_dir <- file.path(save_dir, "CV")
# sapply(c("Init", "Fitted", "Predictions"), function(subdir) {
#   dir.create(file.path(cv_dir, subdir), recursive = TRUE, showWarnings = FALSE)
# })
rtf_file <- file.path(cv_dir, "process_log.rtf")
start_rtf_log(rtf_file)
# # Generate fold indices for cross-validation
# fold_ind <- create_train_test_indices(nrow(hM$Y), n_folds = n_folds)
# saveRDS(fold_ind, file.path(cv_dir, paste0("Folds",n_folds,"_" ,sprintf("S%d_T%d.rds", nSamples, thin))))
fold_ind <- readRDS(file.path(cv_dir, paste0(mod_name,"Folds4_S250_T2000.rds")))
# Loop through each fold
i=1
for (i in 1:n_folds) {
log_message_rtf("rule", sprintf("Processing Fold %d of %d", i, n_folds), rtf_file)
c=1
for (c in 1:nChains){    # Loop on chains
log_message_rtf("info", sprintf("Processing Fold %d of %d, chain %d/%d", i, n_folds,c,nChains), rtf_file)
# Get train and test indices for this fold
train <- fold_ind[[i]]$train
test <- fold_ind[[i]]$test
# Prepare training data for this fold
Y <- hM$Y[train, , drop = FALSE]
XData <- hM$XData[train, , drop = FALSE]
Tr <- hM$Tr
Phy <- hM$phyloTree
studyDesign <- droplevels(hM$dfPi[train, , drop = FALSE])
rLsite <- hM$rL
distr <- hM$distr
rL.year <- HmscRandomLevel(units = studyDesign$year)
rL.location <- HmscRandomLevel(units = studyDesign$grid.cell)
# Create new HMSC model for this fold
hMk <- Hmsc(
Y = Y,
XData = XData,
Tr = Tr,
phyloTree = Phy,
studyDesign = studyDesign,
ranLevels = list(year = rL.year, grid.cell = rL.location),
distr = distr
)
# Initialize MCMC sampling for HPC
log_message_rtf("info", "Initializing for HPC", rtf_file)
transient <- ceiling(nSamples * thin / 2)
init_obj <- sampleMcmc(hMk, samples = nSamples, thin = thin,
transient = transient, nChains = 1,
verbose = verbose, engine = "HPC")
# Save initialization object
init_file <- file.path(cv_dir, paste0(mod,sprintf("init_S%d_T%d_Fold%d_Chain%d.rds", nSamples, thin, i,c)))
# Import and process HPC results
log_message_rtf("info", "Importing HPC results", rtf_file)
}
fitted_chains <- list()
c <- 1
for (c in 1:nChains){
post_file <- file.path(cv_dir, paste0(mod,sprintf("POST_S%d_T%d_Fold%d_Chain%d.rds", nSamples, thin, i,c)))
importFromHPC <- from_json(readRDS(file = post_file)[[1]])
postList <- importFromHPC[1:1]
# Post-process HPC results
log_message_rtf("info", "Post-processing HPC results", rtf_file)
fitted_chains[[c]] <- importPosteriorFromHPC(hMk, postList, nSamples, thin, transient)
log_message_rtf("success", "Post-processing complete", rtf_file)
# Save fitted model
log_message_rtf("info", sprintf("Saving fitted chain %d/%d",c, nChains), rtf_file)
saveRDS(fitted_chains, file.path(cv_dir, paste0(mod,sprintf("fitted_S%d_T%d_Fold%d_Chain%d.rds", nSamples, thin, i,c))))
log_message_rtf("success", sprintf("Fitted chain %d/%d saved",c, nChains), rtf_file)
}
# Save fitted model
log_message_rtf("info", "Saving fitted model", rtf_file)
fitted_model <- do.call(base::c, fitted_chains)
saveRDS(fitted_model, file.path(cv_dir, paste0(mod,sprintf("fitted_S%d_T%d_Fold%d.rds", nSamples, thin, i))))
log_message_rtf("success", "Fitted model saved", rtf_file)
# Prepare testing data
testing <- list(
Y = hM$Y[test, , drop = FALSE],
XData = hM$XData[test, , drop = FALSE],
studyDesign = droplevels(hM$dfPi[test, , drop = FALSE])
)
testing$studyDesign$site <- factor(1:nrow(testing$Y))
rownames(testing$studyDesign) <- paste0("site_", 1:nrow(testing$Y))
# Compute predictions for test data
log_message_rtf("info", "Computing predictions", rtf_file)
preds <- predict(fitted_model,
XData = testing$XData,
studyDesign = testing$studyDesign,
expected =TRUE,
predictEtaMean  = TRUE)
# Ensure predictions are in array format
preds <- simplify2array(preds)
# Save predictions for this fold
# saveRDS(preds, file.path(cv_dir, paste0(mod,sprintf("preds_S%d_T%d_Fold%d.rds", nSamples, thin, i))))
# log_message_rtf("success", "Predictions computed and saved", rtf_file)
log_message_rtf("success", "Predictions computed", rtf_file)
# test preds dimensions
cat("\nFOLD", i, "\n")
cat("length(test):", length(test), "\n")
cat("dim(preds):", paste(dim(preds), collapse = " x "), "\n")
if (i == 1) {
full_pred_array <- initialize_prediction_array(
n_rows = nrow(hM$Y),
n_species = dim(preds)[2],
n_samples = dim(preds)[3]
)
saveRDS(full_pred_array, file.path(cv_dir, sprintf("Empty_Pred_Array_S%d_T%d_Fold%d.rds", nSamples, thin, i)))
}
# Store predictions in the full prediction array
full_pred_array[test, , ] <- preds
log_message_rtf("success", sprintf("Processing complete for Fold %d", i), rtf_file)
log_message_rtf("rule", "End of fold", rtf_file)
}
# Save the full prediction array containing results from all folds
# saveRDS(full_pred_array, file.path(cv_dir, "full_prediction_array.rds"))
saveRDS(full_pred_array, file.path(cv_dir, paste0(mod,sprintf("PredArray_CV_S%d_T%d.rds", nSamples, thin))))
log_message_rtf("success", "Full prediction array saved", rtf_file)
log_message_rtf("success", "HMSC model fitting and prediction completed for all folds.", rtf_file)
end_rtf_log(rtf_file)
predY=computePredictedValues(m)
saveRDS(predY, file.path(cv_dir, paste0(mod,sprintf("PredArray_FULL_MOD0_S%d_T%d.rds", nSamples, thin))))
